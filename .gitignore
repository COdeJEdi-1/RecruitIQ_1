# secrets — never commit
.env
*.env
!*.env.example

# logs
logs/
*.log

# OS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo

# Node
node_modules/

# Build artifacts
dist/
build/

# Agent tooling metadata — not part of the application
.claude-flow/

# Legacy pre-MySQL flat-file data store (superseded by the recruitiq DB)
darwin_data/

# Legacy SQLite files (MySQL is now the default datastore)
*.db

# Local DB backups/dumps — may contain real data, never commit
backups/

# AI_VoiceAgent local runtime state (generated, not source)
AI_VoiceAgent/server/data/*.json
AI_VoiceAgent/server/data/reports/
!AI_VoiceAgent/server/data/settings.json
