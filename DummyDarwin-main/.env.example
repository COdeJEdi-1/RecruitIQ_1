SECRET_KEY=dev-secret-key-change-in-production
PORT=6002

# Phase 3: MySQL is the default. Set USE_SQLITE=true to fall back to the
# local SQLite file (e.g. offline development).
USE_SQLITE=false

# Shared with jd_prototype; both modules connect to the same 'recruitiq'
# database, kept logically separate via distinct tables/models rather than
# separate databases.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=recruitiq
MYSQL_USER=root
MYSQL_PASSWORD=
# Optional full URI override:
# DATABASE_URL=mysql+pymysql://user:pass@127.0.0.1:3306/recruitiq?charset=utf8mb4
