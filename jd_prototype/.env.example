GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
COMPANY_NAME=Arvind GCC

# MySQL (Phase 3 primary datastore — SQLAlchemy). Shared with DummyDarwin-main;
# both modules connect to the same 'recruitiq' database, kept logically
# separate via distinct tables/models rather than separate databases.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=recruitiq
MYSQL_USER=root
MYSQL_PASSWORD=
# Optional full URI override:
# DATABASE_URL=mysql+pymysql://user:pass@127.0.0.1:3306/recruitiq?charset=utf8mb4

FLASK_SECRET_KEY=change-this-to-a-long-random-string
# DEV_MODE relaxes local-login gating for local development only.
DEV_MODE=false
ADMIN_EMAILS=
PORT=6001

# Auto-screening handoff — candidates scoring >= 80 get pushed here (must match
# WEBHOOK_SECRET in AI_VoiceAgent/.env)
VOICE_AGENT_WEBHOOK_URL=http://localhost:6003/api/candidates/inbound
WEBHOOK_SECRET=
