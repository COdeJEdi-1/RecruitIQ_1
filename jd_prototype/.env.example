GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
COMPANY_NAME=Arvind GCC

# Supabase Auth — create a project at https://supabase.com/dashboard
# Settings → API → Project URL and anon/public key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service_role key — Settings → API → service_role (secret!).
# Only used server-side to mirror approved Sample JD Library entries into
# the role_taxonomy / sample_jds tables (see supabase_schema.sql). Bypasses
# RLS — never expose this key to the browser or commit it anywhere.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

FLASK_SECRET_KEY=change-this-to-a-long-random-string
