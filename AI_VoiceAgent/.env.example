# OmniDimension
VITE_OMNIDIM_AGENT_ID=
VITE_OMNIDIM_API_KEY=
VITE_OMNIDIM_PHONE_NUMBER_ID=
VITE_OMNIDIM_CONCURRENT_CALLS=4

# Post-call webhook receiver (server/webhookServer.mjs)
VITE_WEBHOOK_SECRET=
WEBHOOK_SECRET=
VITE_WEBHOOK_PUBLIC_URL=
WEBHOOK_PUBLIC_URL=
# Base URL the browser uses to reach server/webhookServer.mjs directly (auto-call toggle, bulk upload)
VITE_WEBHOOK_SERVER_URL=http://localhost:6003

# Auto-screening safety switch — see server/webhookServer.mjs
VOICE_AGENT_DRY_RUN=true
VOICE_AGENT_TEST_PHONE=

# Batch window (ms) for grouping auto-dispatched calls into one report — default 10 min
VOICE_AGENT_BATCH_WINDOW_MS=600000
